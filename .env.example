# Server Configuration
PORT=3000
NODE_ENV=production

# Brapi API Configuration
BRAPI_API_KEY=your_brapi_api_key_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=24h

# Cache Configuration
CACHE_TTL=900000
SCHEDULER_INTERVAL=15

# Next.js
NEXT_TELEMETRY_DISABLED=1
